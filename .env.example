# Database
DATABASE_URL="postgresql://user:password@localhost:5432/2way_lock_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@2waylock.com"

# OpenAI
OPENAI_API_KEY="sk-..."

# File Upload & Scanning
AWS_S3_BUCKET="2way-lock-uploads"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"
MAX_FILE_SIZE_MB=500
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"
VIRUSTOTAL_API_KEY="your-virustotal-key"

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_API_KEY="your-key"

# App
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"

# Admin
ADMIN_EMAIL="admin@2waylock.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# AI Matching
AI_MATCH_CACHE_TTL="86400"
AI_CALLS_PER_USER_PER_DAY="50"
